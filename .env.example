# Aether Core AI — Environment Variables Example
# Duplicate this file to '.env' and fill in your keys for local development.
# For Vercel deployment, configure these keys in your Vercel Project Settings.

# 1. Google Gemini Configuration (Primary AI engine)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Comma-separated list of Gemini keys for rotation and 12-node failover mesh simulation
GOOGLE_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2

# Optional: Google model override (defaults to gemini-2.5-flash)
GOOGLE_MODEL=gemini-2.5-flash

# 2. xAI Grok Configuration (Primary / Failover AI engine)
XAI_API_KEY=your_xai_grok_api_key_here

# Optional: xAI model override (defaults to grok-2)
XAI_MODEL=grok-2

# 3. Firebase Configuration (Optional: for syncing the live agent status badge)
FIREBASE_DB_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_DB_AUTH=your_firebase_database_secret_token
